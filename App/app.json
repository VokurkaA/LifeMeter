{
  "expo": {
    "name": "LifeMeter",
    "slug": "LifeMeter",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./src/assets/logo.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "$(PRODUCT_NAME) needs access to your Camera.",
        "NSHealthShareUsageDescription": "$(PRODUCT_NAME) needs to access your health data to track your fitness and wellness.",
        "NSHealthUpdateUsageDescription": "$(PRODUCT_NAME) needs to update your health data to log your activities."
      },
      "bundleIdentifier": "com.anonymous.LifeMeter",
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.access": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./src/assets/logo.png"
      },
      "usesCleartextTraffic": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_HEIGHT",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_BLOOD_PRESSURE",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_HEALTH_DATA_HISTORY",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.anonymous.LifeMeter"
    },
    "plugins": [
      "expo-router",
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "$(PRODUCT_NAME) needs to access your health data to track your fitness and wellness.",
          "NSHealthUpdateUsageDescription": "$(PRODUCT_NAME) needs to update your health data to log your activities.",
          "background": false
        }
      ],
      "expo-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ffffff",
          "sounds": []
        }
      ]
    ]
  }
}
